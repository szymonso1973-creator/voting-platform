generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum VotingSessionStatus {
  ACTIVE
  SUBMITTED
  EXPIRED
  REVOKED
}

enum VoteValue {
  FOR
  AGAINST
  ABSTAIN
}

enum AuditAction {
  SESSION_VIEW
  DRAFT_SAVED
  VOTES_SUBMITTED
  ADMIN_LOGIN
  ADMIN_LOGOUT
  ADMIN_REMIND
  ADMIN_CLOSE_VOTING
  ADMIN_EXPORT_PROTOCOL
}

enum DocumentType {
  RECEIPT
  PROTOCOL
}

enum AdminRole {
  SUPER_ADMIN
  ORG_ADMIN
  OPERATOR
  VIEWER
}

enum DeliveryStatus {
  PENDING
  SENT
  FAILED
}

model Organization {
  id        String          @id @default(cuid())
  name      String
  slug      String          @unique
  isActive  Boolean         @default(true)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  admins    AdminUser[]
  voters    Voter[]
  votings   VotingSession[]
}

model AdminUser {
  id           String        @id @default(cuid())
  email        String        @unique
  fullName     String
  passwordHash String
  role         AdminRole
  isActive     Boolean       @default(true)
  lastLoginAt  DateTime?
  orgId        String?
  organization Organization? @relation(fields: [orgId], references: [id], onDelete: Cascade)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Voter {
  id             String           @id @default(cuid())
  orgId          String
  organization   Organization     @relation(fields: [orgId], references: [id], onDelete: Cascade)
  fullName       String
  email          String           @unique
  identifier     String?
  shares         String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  votingSessions VotingSession[]
  deliveries     VotingDelivery[]
}

model VotingSession {
  id              String              @id @default(cuid())
  orgId           String
  organizationRef Organization        @relation(fields: [orgId], references: [id], onDelete: Cascade)
  publicId        String              @unique
  organization    String
  title           String
  tokenHash       String              @unique
  deadline        DateTime
  status          VotingSessionStatus @default(ACTIVE)
  submittedAt     DateTime?
  draftSavedAt    DateTime?
  allowDraft      Boolean             @default(true)
  allowPdfPreview Boolean             @default(true)
  voterId         String
  voter           Voter               @relation(fields: [voterId], references: [id], onDelete: Cascade)
  resolutions     Resolution[]
  auditLogs       AuditLog[]
  documents       Document[]
  deliveries      VotingDelivery[]
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
}

model Resolution {
  id              String        @id @default(cuid())
  number          String
  subject         String
  description     String
  pdfUrl          String?
  sortOrder       Int
  votingSessionId String
  votingSession   VotingSession @relation(fields: [votingSessionId], references: [id], onDelete: Cascade)
  ballot          Ballot?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model Ballot {
  id           String     @id @default(cuid())
  vote         VoteValue
  isDraft      Boolean    @default(true)
  submittedAt  DateTime?
  resolutionId String     @unique
  resolution   Resolution @relation(fields: [resolutionId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model AuditLog {
  id              String        @id @default(cuid())
  action          AuditAction
  ipAddress       String?
  userAgent       String?
  metadata        Json?
  votingSessionId String
  votingSession   VotingSession @relation(fields: [votingSessionId], references: [id], onDelete: Cascade)
  createdAt       DateTime      @default(now())
}

model Document {
  id              String        @id @default(cuid())
  type            DocumentType
  fileUrl         String
  votingSessionId String
  votingSession   VotingSession @relation(fields: [votingSessionId], references: [id], onDelete: Cascade)
  createdAt       DateTime      @default(now())
}

model VotingDelivery {
  id             String         @id @default(cuid())
  votingSessionId String
  voterId        String
  email          String
  deliveryStatus DeliveryStatus @default(PENDING)
  sentAt         DateTime?
  errorMessage   String?
  createdAt      DateTime       @default(now())
  votingSession  VotingSession  @relation(fields: [votingSessionId], references: [id], onDelete: Cascade)
  voter          Voter          @relation(fields: [voterId], references: [id], onDelete: Cascade)
}
